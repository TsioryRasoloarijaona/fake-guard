@{
    ViewBag.Title = "Analysis History";
}

<div class="page-header">
    <div class="container d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h1>Analysis History</h1>
            <p>All articles previously submitted for analysis.</p>
        </div>
        <a href="@Url.Action("Submit", "Article")" class="btn btn-accent">
            + New Analysis
        </a>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            @* Empty state — shown when no articles exist *@
            @*
            <div class="alert alert-info">
                No articles analyzed yet.
                <a href="@Url.Action("Submit", "Article")">Submit your first article →</a>
            </div>
            *@

            <!-- Static example entries -->
            <ul class="list-group">

                <a href="@Url.Action("Details", "Result")" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 font-weight-bold">Scientists Claim Moon Is Made of Cheese, NASA Confirms</p>
                            <small class="text-muted">example-news.com/moon-cheese</small><br/>
                            <small class="text-muted">25 May 2026, 14:32 UTC</small>
                        </div>
                        <div class="text-right ml-3 flex-shrink-0">
                            <span class="badge badge-danger badge-pill">FAKE</span><br/>
                            <small class="text-muted">91%</small>
                        </div>
                    </div>
                </a>

                <a href="@Url.Action("Details", "Result")" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 font-weight-bold">WHO Reports Global Malaria Cases Down 15% in 2025</p>
                            <small class="text-muted">reuters.com/health/malaria-2025</small><br/>
                            <small class="text-muted">24 May 2026, 09:10 UTC</small>
                        </div>
                        <div class="text-right ml-3 flex-shrink-0">
                            <span class="badge badge-success badge-pill">REAL</span><br/>
                            <small class="text-muted">87%</small>
                        </div>
                    </div>
                </a>

                <a href="@Url.Action("Details", "Result")" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="mb-1 font-weight-bold">Is the New Economic Plan Good for the Middle Class?</p>
                            <small class="text-muted">opiniontoday.net/economy-plan</small><br/>
                            <small class="text-muted">23 May 2026, 17:45 UTC</small>
                        </div>
                        <div class="text-right ml-3 flex-shrink-0">
                            <span class="badge badge-warning badge-pill">UNCERTAIN</span><br/>
                            <small class="text-muted">58%</small>
                        </div>
                    </div>
                </a>

            </ul>

        </div>
    </div>
</div>
